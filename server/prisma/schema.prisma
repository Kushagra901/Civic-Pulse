generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}


enum Role {
  CITIZEN
  MODERATOR
  ADMIN
  WORKER_TEAM
}

enum IncidentStatus {
  REPORTED
  TRIAGED
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  VERIFIED
  CLOSED
}

enum ConfirmationType {
  CONFIRM
  DISPUTE
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CITIZEN)
  trustScore   Int      @default(0)
  refreshToken String?
  isBanned     Boolean  @default(false)
  createdAt    DateTime @default(now())

  incidentsCreated Incident[]      @relation("CreatedIncidents")
  reports          Report[]
  confirmations    Confirmation[]
  timelineEvents   TimelineEvent[]
  notifications    Notification[]
}

model Incident {
  id          String         @id @default(uuid())
  title       String
  description String
  category    String
  status      IncidentStatus @default(REPORTED)

  // 🔥 Geo-spatial location
  location Unsupported("geography(Point,4326)")

  // Full-text search vector — maintained by a Postgres trigger
  searchVector Unsupported("tsvector")?

  severityScore     Int   @default(1)
  credibilityScore  Int   @default(0)
  clusterConfidence Float @default(1.0)
  isFlagged         Boolean @default(false)

  createdAt DateTime @default(now())

  // relations
  createdById String?
  createdBy   User?   @relation("CreatedIncidents", fields: [createdById], references: [id])

  reports        Report[]
  confirmations  Confirmation[]
  timelineEvents TimelineEvent[]
  assignments    Assignment[]

  @@index([createdAt(sort: Desc), id(sort: Desc)])   // cursor pagination
  @@index([status, category])                         // filter queries
  @@index([credibilityScore(sort: Desc)])             // sort by score
  @@index([searchVector], type: Gin)
}

model Report {
  id         String   @id @default(uuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id])

  reportedById String
  reportedBy   User   @relation(fields: [reportedById], references: [id])

  description String
  photoUrls   Json?
  lat         Float
  lng         Float

  createdAt DateTime @default(now())

  @@index([incidentId, createdAt])
}

model Confirmation {
  id         String   @id @default(uuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  type      ConfirmationType
  createdAt DateTime         @default(now())

  @@unique([incidentId, userId])
}

model TimelineEvent {
  id         String   @id @default(uuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id])

  actorId String
  actor   User   @relation(fields: [actorId], references: [id])

  eventType  String
  fromStatus IncidentStatus?
  toStatus   IncidentStatus?
  meta       Json?
  createdAt  DateTime        @default(now())

  @@index([incidentId, createdAt(sort: Desc)])        // timeline pagination
}

model Assignment {
  id         String   @id @default(uuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id])

  teamName   String
  assignedBy String
  active     Boolean  @default(true)
  assignedAt DateTime @default(now())
}

model Notification {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  type       String    // STATUS_CHANGE | REPORT_ADDED | CONFIRMATION
  title      String
  body       String
  incidentId String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
}
