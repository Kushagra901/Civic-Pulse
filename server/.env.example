# ═══════════════════════════════════════════════════════════════
# CivicPulse — Server Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in every value before running.
# Never commit .env to version control.
#
# Generate secure random secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ═══════════════════════════════════════════════════════════════

# ── Runtime ────────────────────────────────────────────────────

# 'development' | 'production' | 'test'
# Controls logging verbosity, HTTPS enforcement, pino-pretty, etc.
NODE_ENV=development

# Port the Express server listens on.
# Render/Railway inject their own PORT — don't hardcode 3000 in code.
PORT=3000

# ── Database ───────────────────────────────────────────────────

# Full PostgreSQL connection string with PostGIS extension.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Local Docker:  postgresql://postgres:postgres@localhost:5432/civicpulse
# Render:        provided automatically when you attach a Postgres instance
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/civicpulse?schema=public

# Optional shadow database URL for migrations
SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/civicpulse_shadow?schema=public

# Connection pool size. Default is fine for most deployments.
# Increase only if your DB plan supports more concurrent connections.
# Render free tier: max 5. Render starter: max 25.
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ──────────────────────────────────────────────────────

# Full Redis connection URL.
# Local Docker:  redis://localhost:6379
# Render:        provided when you attach a Redis instance
# Upstash:       rediss://default:TOKEN@host:6380 (note: rediss:// for TLS)
REDIS_URL=redis://localhost:6379

# ── JWT ────────────────────────────────────────────────────────

# MUST be a long, random, unique secret. Treat like a password.
# Changing this invalidates ALL existing access tokens immediately.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_generate_a_64_byte_hex_string

# Short-lived access tokens. 15m is the industry standard.
# Shorter = more secure but more refresh calls. Don't go below 5m.
JWT_ACCESS_EXPIRES_IN=15m

# Different secret from access token — so a leaked refresh token
# cannot be used to forge access tokens and vice versa.
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_different_64_byte_hex_string

# Refresh tokens live longer. 7d is standard for most apps.
# Consider 30d for mobile-first apps where re-login is disruptive.
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ───────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins. No trailing slash.
# Development: http://localhost:5173
# Production:  https://civicpulse.vercel.app,https://civicpulse.app
ALLOWED_ORIGINS=http://localhost:5173

# ── Frontend ───────────────────────────────────────────────────

# Base URL of the React app. Used to build links in emails.
# Must match exactly — trailing slash breaks email links.
CLIENT_URL=http://localhost:5173

# ── Email / SMTP ───────────────────────────────────────────────

# SMTP provider settings for Nodemailer.
# Gmail: use App Passwords (not your login password).
#   Enable at: myaccount.google.com/apppasswords
#   Requires 2FA to be active on the Gmail account.
# Mailgun free tier: 100 emails/day, no credit card.
# Resend free tier:  3000 emails/month.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password

# Display name + address for outgoing mail.
# Use a real domain in production — Gmail often marks noreply@ as spam.
SMTP_FROM="CivicPulse <noreply@civicpulse.app>"

# ── Cloudinary ─────────────────────────────────────────────────

# From your Cloudinary dashboard → Settings → Access Keys.
# The API secret is never sent to the client — only used server-side
# to sign upload URLs.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=CHANGE_ME_from_cloudinary_dashboard

# ── Logging ────────────────────────────────────────────────────

# Pino log level: trace | debug | info | warn | error | fatal
# Development: debug  (verbose, shows all requests)
# Production:  info   (meaningful events only)
LOG_LEVEL=debug

# ── Rate limiting ──────────────────────────────────────────────

# How long (seconds) to lock an account after repeated failed logins.
# Default: 1800 (30 minutes). Increase for higher-security deployments.
ACCOUNT_LOCKOUT_SECS=1800

# Max failed login attempts before lockout triggers.
AUTH_MAX_FAILURES=5

# ── BullMQ ─────────────────────────────────────────────────────

# How many scoring jobs to process in parallel.
# Higher = faster but more DB connections consumed per job.
# Keep at 2–5 on free/starter DB plans.
QUEUE_CONCURRENCY=3

# ── Optional integrations ───────────────────────────────────────

# Open-Meteo is free and requires no API key.
# Set to 'true' to enable weather-based severity boosting.
WEATHER_INTEGRATION_ENABLED=false

# If you add Sentry for error tracking later:
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxxxx
