# ═══════════════════════════════════════════════════════════════
# CivicPulse — Client Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Vite exposes only variables prefixed with VITE_ to the browser.
# Never put secrets here — this bundle is sent to every visitor.
# ═══════════════════════════════════════════════════════════════

# Base URL of your Express API.
# Development: http://localhost:3000
# Production:  https://your-backend.onrender.com
# Leave empty if using Vite's proxy (recommended for development).
VITE_API_URL=http://localhost:3000

# WebSocket URL for Socket.io.
# Usually the same as VITE_API_URL — Socket.io uses the same port.
VITE_SOCKET_URL=http://localhost:3000

# Your Cloudinary cloud name — used client-side to build upload URLs.
# This is public — it's visible in every upload request.
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# App display name — lets you run staging/prod with different names.
VITE_APP_NAME=CivicPulse

# Your deployed frontend URL. Used for OG tags and share links.
VITE_APP_URL=http://localhost:5173
